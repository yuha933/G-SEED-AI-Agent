                }
              ],
              "derived_variables": [
                {
                  "name": "method_1_epi_score",
                  "formula": "0 if energy_performance_index_total_score < 70 else min(12, round(12 * (0.4 + ((energy_performance_index_total_score - 70) / 25) * 0.6), 2))",
                  "unit": "점"
                },
                {
